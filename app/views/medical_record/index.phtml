                <?php if ($currentUser->isDoctor()): ?>
                    <a href="<?= route('medical_records.new') ?>" class="btn btn-outline-primary mt-3">
                        Criar primeiro prontuário
                    </a>
                <?php endif; ?>
            </div>
        </div>

    <?php else: ?>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">#</th>
                                <th>Paciente</th>
                                <th>Médico</th>
                                <th>Data do Registro</th>
                                <th>Diagnóstico</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($medicalRecords as $record): ?>
                                <?php
                                $patient = $record->patient();
                                $doctor  = $record->doctor();
                                $patientUser = $patient ? $patient->user() : null;
                                $doctorUser = $doctor ? $doctor->user() : null;
                                ?>
                                <tr>
                                    <td class="ps-4 text-muted"><?= $record->id ?></td>

                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-light text-dark border">
                                                <i class="bi bi-person me-1"></i>
                                                <?= htmlspecialchars($patientUser ? $patientUser->name : 'Paciente desconhecido') ?>
                                            </span>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="text-muted">
                                            <?= htmlspecialchars($doctorUser ? $doctorUser->name : 'Médico desconhecido') ?>
                                        </span>
                                    </td>

                                    <td>
                                        <?php
                                        $date = \DateTime::createFromFormat('Y-m-d', $record->record_date);
                                        echo $date ? $date->format('d/m/Y') : htmlspecialchars($record->record_date);
                                        ?>
                                    </td>

                                    <td>
                                        <?= htmlspecialchars(mb_substr($record->diagnosis, 0, 60)) ?>
                                        <?php if (mb_strlen($record->diagnosis) > 60): ?>
                                            <span class="text-muted">…</span>
                                        <?php endif; ?>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <a href="<?= route('medical_records.show', ['id' => $record->id]) ?>"
                                                class="btn btn-sm btn-outline-secondary" title="Visualizar">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <?php if ($currentUser->isDoctor()): ?>
                                                <a href="<?= route('medical_records.edit', ['id' => $record->id]) ?>"
