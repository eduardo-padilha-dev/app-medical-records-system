                                                    <i class="bi bi-pencil"></i>
                                                </a>

                                                <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Excluir"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalDelete"
