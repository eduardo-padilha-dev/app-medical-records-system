?>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary">
                <i class="bi bi-file-earmark-medical me-2"></i>Prontuários Médicos
