$hasFile = $exam->file_path !== null && $exam->file_path !== '';

$statusClass = 'secondary';
$statusText = $exam->ai_status;

if ($exam->ai_status === App\Models\Exam::STATUS_PENDING) {
    $statusClass = 'warning';
    $statusText = 'Pendente';
} elseif ($exam->ai_status === App\Models\Exam::STATUS_PROCESSING) {
    $statusClass = 'info';
    $statusText = 'Processando';
} elseif ($exam->ai_status === App\Models\Exam::STATUS_COMPLETED) {
    $statusClass = 'success';
    $statusText = 'Concluído';
} elseif ($exam->ai_status === App\Models\Exam::STATUS_FAILED) {
    $statusClass = 'danger';
    $statusText = 'Falhou';
}
