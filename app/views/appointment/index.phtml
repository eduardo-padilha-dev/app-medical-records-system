<?php
/** @var string $title */
/** @var string $subtitle */
/** @var array $appointments */
$currentUser = $this->currentUser();
?>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-primary mb-1">
                <i class="bi bi-calendar-check me-2"></i>
                <?= $title ?>
            </h1>

            <p class="text-muted mb-0">
                <?= $subtitle ?>
            </p>
        </div>
        <?php if ($currentUser && $currentUser->isSecretary()): ?>
            <a href="<?= route('appointments.new') ?>" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Novo Agendamento
            </a>
        <?php endif; ?>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">

            <?php if (empty($appointments)): ?>

                <div class="text-center py-5">
                    <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>

                    <h5 class="mt-3">
                        Nenhum agendamento encontrado
                    </h5>

                    <p class="text-muted">
                        Quando houver agendamentos cadastrados, eles aparecerão aqui.
                    </p>
                    <?php if ($currentUser && $currentUser->isSecretary()): ?>
                        <a href="<?= route('appointments.new') ?>" class="btn btn-primary">
                            Criar primeiro agendamento
                        </a>
                    <?php endif; ?>
                </div>

            <?php else: ?>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Paciente</th>
                                <th>Médico</th>
                                <th>Data/Hora</th>
                                <th>Status</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>

                        <tbody>
                            <?php foreach ($appointments as $appointment): ?>
                                <?php
                                    $patient = $appointment->patient()->get();
                                    $doctor = $appointment->doctor()->get();

                                    $patientUser = $patient ? $patient->user()->get() : null;
                                    $doctorUser = $doctor ? $doctor->user()->get() : null;

                                    $statusClass = 'secondary';
                                    $statusText = $appointment->status;

                                    if ($appointment->status === 'scheduled') {
                                        $statusClass = 'warning';
                                        $statusText = 'Agendado';
                                    } elseif ($appointment->status === 'confirmed') {
                                        $statusClass = 'primary';
                                        $statusText = 'Confirmado';
                                    } elseif ($appointment->status === 'completed') {
                                        $statusClass = 'success';
                                        $statusText = 'Concluído';
                                    } elseif ($appointment->status === 'canceled') {
                                        $statusClass = 'danger';
                                        $statusText = 'Cancelado';
                                    }
                                ?>

                                <tr>
                                    <td>
                                        #<?= $appointment->id ?>
                                    </td>

                                    <td>
                                        <?= $patientUser ? $patientUser->name : 'Paciente não encontrado' ?>
                                    </td>

                                    <td>
                                        <?= $doctorUser ? $doctorUser->name : 'Médico não encontrado' ?>
                                    </td>

                                    <td>
                                        <?= date('d/m/Y H:i', strtotime($appointment->scheduled_at)) ?>
                                    </td>

                                    <td>
                                        <span class="badge text-bg-<?= $statusClass ?>">
                                            <?= $statusText ?>
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <a href="<?= route('appointments.show', ['id' => $appointment->id]) ?>"
                                                class="btn btn-sm btn-outline-secondary" title="Visualizar">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        
                                            <?php if ($currentUser->isSecretary()): ?>
                                                <a href="<?= route('appointments.edit', ['id' => $appointment->id]) ?>"
                                                    class="btn btn-sm btn-outline-warning" title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>

                                                <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Excluir"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#modalDelete"
                                                    data-record-id="<?= $appointment->id ?>">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            <?php endif; ?>
                                        </div>
                                    </td>
                                </tr>

                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>

            <?php endif; ?>

        </div>
    </div>

    <div class="mt-4">
        <a href="<?= route('auth.check') ?>" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Voltar para o painel
        </a>
    </div>

</div>

<div class="modal fade" id="modalDelete" tabindex="-1" aria-labelledby="modalDeleteLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger" id="modalDeleteLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirmar Exclusão
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Tem certeza que deseja excluir o <strong>Agendamento #<span id="deleteRecordId"></span></strong>?
                <br><span class="text-danger small">Esta ação não pode ser desfeita.</span>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="deleteForm" method="POST" action="">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Excluir
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const modalDelete = document.getElementById('modalDelete');
    modalDelete.addEventListener('show.bs.modal', function(event) {
        const btn = event.relatedTarget;
        const recordId = btn.getAttribute('data-record-id');

        document.getElementById('deleteRecordId').textContent = recordId;
        document.getElementById('deleteForm').action = '/appointments/' + recordId;
    });
</script>
