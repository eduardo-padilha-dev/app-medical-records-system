<?php
/** @var string $title */
/** @var string $subtitle */
/** @var array $appointments */
?>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-primary mb-1">
                <i class="bi bi-calendar-check me-2"></i>
                <?= $title ?>
            </h1>

            <p class="text-muted mb-0">
                <?= $subtitle ?>
            </p>
        </div>

        <a href="<?= route('appointments.new') ?>" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Novo Agendamento
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">

            <?php if (empty($appointments)): ?>

                <div class="text-center py-5">
                    <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>

                    <h5 class="mt-3">
                        Nenhum agendamento encontrado
                    </h5>

                    <p class="text-muted">
                        Quando houver agendamentos cadastrados, eles aparecerão aqui.
                    </p>

                    <a href="<?= route('appointments.new') ?>" class="btn btn-primary">
                        Criar primeiro agendamento
                    </a>
                </div>

            <?php else: ?>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Paciente</th>
                                <th>Médico</th>
                                <th>Data/Hora</th>
                                <th>Status</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>

                        <tbody>
                            <?php foreach ($appointments as $appointment): ?>
                                <?php
                                    $patient = $appointment->patient();
                                    $doctor = $appointment->doctor();

                                    $patientUser = $patient ? $patient->user() : null;
                                    $doctorUser = $doctor ? $doctor->user() : null;

                                    $statusClass = 'secondary';
                                    $statusText = $appointment->status;

                                    if ($appointment->status === 'scheduled') {
                                        $statusClass = 'warning';
                                        $statusText = 'Agendado';
                                    } elseif ($appointment->status === 'confirmed') {
                                        $statusClass = 'primary';
                                        $statusText = 'Confirmado';
                                    } elseif ($appointment->status === 'completed') {
                                        $statusClass = 'success';
                                        $statusText = 'Concluído';
                                    } elseif ($appointment->status === 'canceled') {
                                        $statusClass = 'danger';
                                        $statusText = 'Cancelado';
                                    }
                                ?>

                                <tr>
                                    <td>
                                        #<?= $appointment->id ?>
                                    </td>

                                    <td>
                                        <?= $patientUser ? $patientUser->name : 'Paciente não encontrado' ?>
                                    </td>

                                    <td>
                                        <?= $doctorUser ? $doctorUser->name : 'Médico não encontrado' ?>
                                    </td>

                                    <td>
                                        <?= date('d/m/Y H:i', strtotime($appointment->scheduled_at)) ?>
                                    </td>

                                    <td>
                                        <span class="badge text-bg-<?= $statusClass ?>">
                                            <?= $statusText ?>
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <a
                                            href="<?= route('appointments.show', ['id' => $appointment->id]) ?>"
                                            class="btn btn-sm btn-outline-primary"
                                        >
                                            <i class="bi bi-eye"></i>
                                            Ver
                                        </a>

                                        <a
                                            href="<?= route('appointments.edit', ['id' => $appointment->id]) ?>"
                                            class="btn btn-sm btn-outline-secondary"
                                        >
                                            <i class="bi bi-pencil"></i>
                                            Editar
                                        </a>
                                    </td>
                                </tr>

                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>

            <?php endif; ?>

        </div>
    </div>

    <div class="mt-4">
        <a href="<?= route('secretary.index') ?>" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Voltar para o painel
        </a>
    </div>

</div>
