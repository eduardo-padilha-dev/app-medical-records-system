<form method="POST" action="/login" class="needs-validation" novalidate>
    <div class="mb-3">
        <label for="email" class="form-label text-dark fw-medium small">
            E-mail
        </label>
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-envelope" style="color: #737785;"></i>
            </span>
            <input type="email" class="form-control" id="email" name="email" placeholder="email@example.com" required />
        </div>
    </div>

    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label for="password" class="form-label text-dark fw-medium small mb-0">
                Senha
            </label>
        </div>
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-lock" style="color: #737785;"></i>
            </span>
            <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required />
        </div>
    </div>

    <button type="submit" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2" > Entrar </button>
</form>
